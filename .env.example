# Google Apps Script Web App URL (back-end Sheet via Apps Script)
# Used by: web (via Netlify Function /api/proxy) and mobile (direct)
GOOGLE_SHEET_DB_URL=

# Firebase Admin (used by the Netlify Function to verify ID tokens)
FIREBASE_PROJECT_ID=

# Firebase Web SDK (must also be exposed to the Expo client via EXPO_PUBLIC_*)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
